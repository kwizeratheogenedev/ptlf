{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/",
      "dest": "backend/server.js"
    },
    {
      "src": "/api/:path*",
      "dest": "backend/server.js"
    },
    {
      "src": "/:path*",
      "dest": "backend/server.js"
    }
  ]
}
